# OpenAI (standaard actief)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# DeepSeek (optioneel)
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Welk model is actief: "openai" of "deepseek"
ACTIVE_MODEL=openai

# Pad naar data map (relatief vanuit project root)
DATA_DIR=./data

CALENDAR_PROVIDER=google

GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar
GOOGLE_DEFAULT_CALENDAR_ID=primary

GOOGLE_CALENDAR_WEBHOOK_URL=https://xxxx.ngrok-free.dev/api/google/calendar/webhook

# Token encryptie (verplicht in productie — genereer met: openssl rand -hex 32)
# GOOGLE_TOKEN_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database (optioneel — laat leeg voor JSON fallback in local dev)
# DATABASE_URL=postgresql://mentor:wachtwoord@localhost:5432/mentor

# Notificaties (optioneel)
# NTFY_URL=https://ntfy.sh
# NTFY_TOPIC=mijn-geheime-topic
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# DAILY_BRIEFING_EMAIL_TO=jij@example.com
